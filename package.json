{
  "name": "rc-code-skeletonizer",
  "version": "0.1.0",
  "description": "A tool to analyze TypeScript codebases and generate semantic skeletons for relevant files",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "rc-skel": "dist/cli.js",
    "rc-agent": "dist/agent-cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "start": "npm run build && node dist/cli.js",
    "cli": "npm run build && node dist/cli.js",
    "benchmark": "npm run build && node dist/benchmark.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "typescript",
    "code-analysis",
    "skeleton",
    "ast"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "ts-morph": "^21.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
